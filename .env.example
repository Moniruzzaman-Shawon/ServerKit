# ─────────────────────────────────────────────
#  ServerKit — environment configuration
# ─────────────────────────────────────────────

# Required: password to log in to ServerKit
SK_PASSWORD=serverkit123

# Required: secret key used to sign session tokens (use a long random string)
JWT_SECRET=change-me-to-a-long-random-secret

# Public hostname shown in the UI (optional)
NEXT_PUBLIC_HOSTNAME=my-linux-server

# Server port (default: 3000)
PORT=3000

# Comma-separated list of filesystem roots for the Media browser
MEDIA_ROOTS=/mnt/media,/mnt/webserver

# Docker socket (default: /var/run/docker.sock)
DOCKER_SOCKET=/var/run/docker.sock

# MinIO S3 storage (optional)
# Use http://minio:9000 when running via Docker Compose (service name resolves on sk-net)
# Use http://localhost:9000 when running outside Docker
MINIO_ENDPOINT=http://minio:9000
MINIO_USER=minioadmin
MINIO_PASS=minioadmin

# SQLite database path (default: ./data/serverkit.db)
# DB_PATH=./data/serverkit.db
